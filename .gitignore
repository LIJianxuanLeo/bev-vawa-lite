# data / runs / binaries - never commit
# Anchor to repo root so this does NOT ignore bev_vawa/data/ (the source package).
/data/
/runs/
*.pt
*.ckpt
*.npz
*.mp4
*.gif

# python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.venv/
build/
dist/

# editor / os
.DS_Store
.vscode/
.idea/

# mujoco runtime
MUJOCO_LOG.TXT

# intermediate / backup files
*.bak
*.prev
*.pre_baseline

# LaTeX build artifacts (keep .tex and .pdf, drop everything else)
paper/*.log
paper/*.aux
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk

# training logs (keep structured summaries in results/ only)
/logs/
